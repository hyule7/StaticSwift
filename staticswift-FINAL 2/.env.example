# StaticSwift — Environment Variables
# Copy this file to .env for local dev
# Set ALL of these in Netlify Dashboard > Site Settings > Environment Variables

# ==========================================
# MAIL PROVIDER
# Set to 'fasthosts' to use FastHosts SMTP
# Leave as 'gmail' (or omit) to use Gmail OAuth2
# ==========================================
MAIL_PROVIDER=fasthosts

# ==========================================
# FASTHOSTS SMTP (if MAIL_PROVIDER=fasthosts)
# Your FastHosts control panel > Email > Mailboxes
# ==========================================
SMTP_HOST=mail.staticswift.co.uk
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@staticswift.co.uk
SMTP_PASS=your_fasthosts_mailbox_password

# ==========================================
# GMAIL OAUTH2 (if MAIL_PROVIDER=gmail)
# Only needed if you use Gmail instead of FastHosts
# Get from: console.cloud.google.com
# ==========================================
GMAIL_CLIENT_ID=your_gmail_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_USER=hello@staticswift.co.uk

# ==========================================
# SUPPORT EMAIL (always needed)
# ==========================================
SUPPORT_EMAIL=support@staticswift.co.uk
OWNER_EMAIL=your_personal_email@gmail.com

# ==========================================
# ADMIN
# ==========================================
ADMIN_PASSWORD=choose_a_strong_password_12chars_min

# ==========================================
# STRIPE
# Get from: dashboard.stripe.com > Developers > API Keys
# ==========================================
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PAYMENT_LINK_STARTER=https://buy.stripe.com/your_starter_link
STRIPE_PAYMENT_LINK_ADVANCED=https://buy.stripe.com/your_advanced_link

# ==========================================
# NETLIFY (for client preview deployments)
# app.netlify.com > User Settings > Applications > Personal Access Tokens
# ==========================================
NETLIFY_ACCESS_TOKEN=your_netlify_personal_access_token
NETLIFY_PREVIEW_SITE_ID=your_preview_site_id

# ==========================================
# WHATSAPP & GOOGLE
# ==========================================
WHATSAPP_NUMBER=447000000000
GOOGLE_REVIEW_LINK=https://g.page/r/your_google_review_link/review
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
